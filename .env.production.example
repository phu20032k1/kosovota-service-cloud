NODE_ENV="production"

# PostgreSQL thật
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kosovota?schema=public"

# Tạo bằng: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="THAY_BANG_CHUOI_NGAU_NHIEN_IT_NHAT_32_KY_TU"
OTP_SECRET="THAY_BANG_CHUOI_NGAU_NHIEN_KHAC"
CRON_SECRET="THAY_BANG_CHUOI_NGAU_NHIEN_KHAC"
NEXT_PUBLIC_APP_URL="https://ten-mien-cua-ban.vn"

# Không để mã OTP cố định khi chạy thật
OTP_DEBUG="false"
OTP_CHANNEL="SMS"

# SMS eSMS
NOTIFICATION_DRY_RUN="false"
SMS_PROVIDER="esms"
ESMS_API_KEY=""
ESMS_SECRET_KEY=""
ESMS_BRANDNAME="KOSOVOTA"
ESMS_SANDBOX="false"
ESMS_CALLBACK_URL=""

# Bản đồ/geocoding. OSM vẫn hiển thị bản đồ không cần key.
NEXT_PUBLIC_MAP_PROVIDER="osm"
GEOCODING_ENABLED="false"
GEOCODING_PROVIDER="maptiler"
MAPTILER_SERVER_API_KEY=""
NEXT_PUBLIC_MAPTILER_KEY=""

# Ảnh/video production lưu trên Cloudflare R2
STORAGE_PROVIDER="r2"
ALLOW_LOCAL_UPLOADS="false"
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_REGION="auto"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="kosovota-uploads"
R2_PUBLIC_BASE_URL="https://media.ten-mien-cua-ban.vn"

# Tài khoản tạo lần đầu
SEED_SUPER_ADMIN_PHONE=""
SEED_SUPER_ADMIN_PASSWORD=""
SEED_SUPER_ADMIN_NAME="SUPER ADMIN KOSOVOTA"
SEED_ADMIN_PHONE=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin vận hành KOSOVOTA"

ALLOW_DEMO_SEED="false"

# =========================
# KIỂM THỬ TÍCH HỢP V19
# =========================
# JSON phải khớp đúng tên biến của template Zalo đã được duyệt.
ZALO_ZBS_TEST_TEMPLATE_DATA='{"otp":"123456","code":"123456","expire_time":"5 phút","message":"KOSOVOTA kiểm tra kết nối"}'
# Chỉ dùng cho lệnh npm run test:sms / test:zalo
TEST_PHONE=""
# Chỉ dùng cho lệnh npm run test:map
TEST_ADDRESS="Hồ Hoàn Kiếm, Hà Nội"
