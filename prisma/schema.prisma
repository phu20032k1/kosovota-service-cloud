generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(cuid())
  phone                 String          @unique
  email                 String?
  password              String
  name                  String
  role                  String
  dealerCode            String?
  provinceScope         String?
  active                Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @default(now()) @updatedAt
  managedCustomers      Customer[]      @relation("CustomerOwner")
  assignedServiceOrders ServiceOrder[]  @relation("TechnicianOrders")
  assignedTickets       SupportTicket[] @relation("TicketAssignee")

  @@index([role, active])
  @@index([dealerCode])
}

model Customer {
  id             String             @id @default(cuid())
  name           String
  phone          String             @unique
  email          String?
  address        String?
  notifyChannels String?
  callFrom       String?
  callTo         String?
  segment        String?            @default("STANDARD")
  tags           String?
  satisfaction   Int?
  birthday       DateTime?
  lastContactAt  DateTime?
  nextContactAt  DateTime?
  ownerId        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  owner          User?              @relation("CustomerOwner", fields: [ownerId], references: [id])
  activities     CustomerActivity[]
  machines       Machine[]
  tickets        SupportTicket[]
}

model Dealer {
  id                 String          @id @default(cuid())
  dealerCode         String          @unique
  name               String
  phone              String
  email              String?
  province           String?
  address            String?
  lat                Float?
  lng                Float?
  services           String?
  technicianCount    Int?
  representativeName String?
  registrationType   String?
  companyName        String?
  birthDate          DateTime?
  locationType       String?
  serviceArea        String?
  taxCode            String?
  citizenId          String?
  bankAccount        String?
  accountHolder      String?
  bankName           String?
  portraitPhoto      String?
  storePhoto         String?
  warehousePhoto     String?
  videoName          String?
  rating             Float?          @default(5)
  status             String          @default("PENDING")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt
  paymentBatches     PaymentBatch[]
  serviceOrders      ServiceOrder[]
  supportTickets     SupportTicket[]
  warehouse          Warehouse?

  @@index([status, province])
  @@index([phone])
}

model Machine {
  id                   String                @id
  model                String
  name                 String?
  capacity             String?
  specification        String?
  warrantyMonths       Int?
  serial               String?               @unique
  provinceCode         String?
  status               String                @default("NEW")
  manufactureDate      DateTime?
  installDate          DateTime?
  customerId           String?
  lat                  Float?
  lng                  Float?
  buildingPhoto        String?
  machinePhoto         String?
  sharedPhones         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  activations          Activation[]
  customer             Customer?             @relation(fields: [customerId], references: [id])
  maintenanceSchedules MaintenanceSchedule[]
  serviceOrders        ServiceOrder[]
  serviceReports       ServiceReport[]
  sosTickets           SosTicket[]
  supportTickets       SupportTicket[]

  @@index([customerId])
  @@index([status])
  @@index([provinceCode])
}

model Activation {
  id             String   @id @default(cuid())
  machineId      String
  step           Int
  installerName  String?
  installerPhone String?
  dealerCode     String?
  ownerName      String?
  ownerPhone     String?
  note           String?
  bankAccount    String?
  bankOwner      String?
  bankName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([machineId, step])
  @@index([machineId])
  @@index([dealerCode])
}

model ServiceOrder {
  id                    String               @id @default(cuid())
  orderCode             String               @unique
  machineId             String
  dealerId              String?
  technicianId          String?
  maintenanceScheduleId String?              @unique
  customerName          String
  customerPhone         String
  address               String?
  serviceType           String
  status                String               @default("NEW")
  rejectReason          String?
  rejectedAt            DateTime?
  dueDate               DateTime?
  serviceFee            Int?
  paymentStatus         String               @default("PENDING")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  paymentLine           PaymentLine?
  dealer                Dealer?              @relation(fields: [dealerId], references: [id])
  machine               Machine              @relation(fields: [machineId], references: [id])
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id])
  technician            User?                @relation("TechnicianOrders", fields: [technicianId], references: [id])
  reports               ServiceReport[]
  stockMovements        StockMovement[]

  @@index([machineId])
  @@index([dealerId])
  @@index([technicianId])
  @@index([status, dueDate])
}

model ServiceReport {
  id           String        @id @default(cuid())
  machineId    String
  orderId      String?
  dealerCode   String?
  serviceType  String
  products     String?
  oldCorePhoto String?
  newCorePhoto String?
  finalPhoto   String?
  signature    String?
  note         String?
  createdAt    DateTime      @default(now())
  machine      Machine       @relation(fields: [machineId], references: [id])
  order        ServiceOrder? @relation(fields: [orderId], references: [id])

  @@index([machineId])
  @@index([orderId])
}

model MaintenanceSchedule {
  id           String        @id @default(cuid())
  machineId    String
  title        String
  dueDate      DateTime
  status       String        @default("PENDING")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  machine      Machine       @relation(fields: [machineId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder?

  @@index([machineId])
  @@index([dueDate, status])
}

model Notification {
  id                String    @id @default(cuid())
  phone             String?
  email             String?
  recipientName     String?
  channel           String
  kind              String?
  subject           String?
  content           String
  payload           String?
  status            String    @default("PENDING")
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5)
  providerMessageId String?
  error             String?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@index([phone, status])
  @@index([email, status])
  @@index([channel, status])
  @@index([status, createdAt])
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  detail    String?
  ipAddress String?
  userAgent String?
  requestId String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model SosTicket {
  id            String   @id @default(cuid())
  machineId     String
  customerName  String
  customerPhone String
  address       String?
  note          String?
  status        String   @default("NEW")
  priority      String   @default("HIGH")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  machine       Machine  @relation(fields: [machineId], references: [id])

  @@index([status, priority, createdAt])
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
}

model IdSequence {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model SalesLead {
  id          String   @id @default(cuid())
  productSlug String?
  fullName    String
  phone       String
  province    String?
  note        String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([phone])
}

model InventoryItem {
  id        String          @id @default(cuid())
  sku       String          @unique
  name      String
  category  String
  unit      String          @default("cái")
  minStock  Int             @default(0)
  costPrice Int             @default(0)
  salePrice Int             @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  balances  StockBalance[]
  movements StockMovement[]

  @@index([category, active])
}

model Warehouse {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  type              String          @default("CENTRAL")
  dealerId          String?         @unique
  province          String?
  address           String?
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  balances          StockBalance[]
  outgoingMovements StockMovement[] @relation("MovementFromWarehouse")
  incomingMovements StockMovement[] @relation("MovementToWarehouse")
  dealer            Dealer?         @relation(fields: [dealerId], references: [id])

  @@index([type, active])
}

model StockBalance {
  id          String        @id @default(cuid())
  warehouseId String
  itemId      String
  quantity    Int           @default(0)
  reserved    Int           @default(0)
  updatedAt   DateTime      @default(now()) @updatedAt
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, itemId])
  @@index([itemId, quantity])
}

model StockMovement {
  id              String        @id @default(cuid())
  movementCode    String        @unique
  type            String
  itemId          String
  fromWarehouseId String?
  toWarehouseId   String?
  serviceOrderId  String?
  quantity        Int
  unitCost        Int           @default(0)
  note            String?
  createdById     String?
  createdAt       DateTime      @default(now())
  fromWarehouse   Warehouse?    @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  item            InventoryItem @relation(fields: [itemId], references: [id])
  serviceOrder    ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  toWarehouse     Warehouse?    @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id])

  @@index([itemId, createdAt])
  @@index([serviceOrderId])
  @@index([fromWarehouseId, createdAt])
  @@index([toWarehouseId, createdAt])
}

model PaymentBatch {
  id            String        @id @default(cuid())
  batchCode     String        @unique
  dealerId      String
  periodStart   DateTime
  periodEnd     DateTime
  status        String        @default("DRAFT")
  grossAmount   Int           @default(0)
  deductions    Int           @default(0)
  netAmount     Int           @default(0)
  bankReference String?
  note          String?
  approvedAt    DateTime?
  paidAt        DateTime?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  dealer        Dealer        @relation(fields: [dealerId], references: [id])
  lines         PaymentLine[]

  @@index([dealerId, status])
  @@index([periodStart, periodEnd])
}

model PaymentLine {
  id              String       @id @default(cuid())
  batchId         String
  serviceOrderId  String       @unique
  serviceAmount   Int          @default(0)
  materialAmount  Int          @default(0)
  bonusAmount     Int          @default(0)
  deductionAmount Int          @default(0)
  totalAmount     Int          @default(0)
  createdAt       DateTime     @default(now())
  batch           PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([batchId])
}

model SupportTicket {
  id           String          @id @default(cuid())
  ticketCode   String          @unique
  type         String          @default("WARRANTY")
  source       String          @default("STAFF")
  subject      String
  description  String?
  status       String          @default("NEW")
  priority     String          @default("NORMAL")
  customerId   String?
  machineId    String?
  dealerId     String?
  assigneeId   String?
  contactName  String
  contactPhone String
  dueAt        DateTime?
  resolvedAt   DateTime?
  satisfaction Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt
  assignee     User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  customer     Customer?       @relation(fields: [customerId], references: [id])
  dealer       Dealer?         @relation(fields: [dealerId], references: [id])
  machine      Machine?        @relation(fields: [machineId], references: [id])
  messages     TicketMessage[]

  @@index([status, priority, createdAt])
  @@index([customerId])
  @@index([machineId])
  @@index([dealerId])
  @@index([assigneeId, status])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  authorId   String?
  authorName String
  message    String
  attachment String?
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model CustomerActivity {
  id         String   @id @default(cuid())
  customerId String
  type       String
  summary    String
  detail     String?
  userId     String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, occurredAt])
  @@index([type, occurredAt])
}
