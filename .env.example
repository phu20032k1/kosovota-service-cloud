# =========================
# DATABASE & SECURITY
# =========================
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
SESSION_SECRET="replace-with-at-least-32-random-characters"
OTP_SECRET="replace-with-a-different-random-secret"
OTP_DEBUG="false"
# Chỉ dùng local test. Không đặt OTP_FIXED_CODE trên production.
# OTP_FIXED_CODE="123456"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =========================
# MAP: osm | maptiler | google
# =========================
# osm: chạy thử không cần key
# maptiler: lớp nền đẹp, cấu hình nhanh
# google: Google Maps JavaScript API
NEXT_PUBLIC_MAP_PROVIDER="osm"
NEXT_PUBLIC_MAPTILER_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Key phía server, không có tiền tố NEXT_PUBLIC
MAPTILER_SERVER_API_KEY=""
GOOGLE_MAPS_SERVER_API_KEY=""
GEOCODING_PROVIDER="maptiler"
GEOCODING_ENABLED="false"

# =========================
# NOTIFICATION QUEUE
# =========================
# Giữ true tới khi kiểm thử xong. false mới gửi thật ra nhà cung cấp.
NOTIFICATION_DRY_RUN="true"
OTP_CHANNEL="SMS"

# SMS qua eSMS
SMS_PROVIDER="esms"
ESMS_API_KEY=""
ESMS_SECRET_KEY=""
ESMS_BRANDNAME=""
ESMS_SANDBOX="true"
ESMS_CALLBACK_URL=""

# Zalo Business Solutions Template Message
ZALO_PROVIDER="zbs"
ZALO_ZBS_ACCESS_TOKEN=""
ZALO_ZBS_TEMPLATE_ID=""
ZALO_ZBS_OTP_TEMPLATE_ID=""
ZALO_ZBS_SERVICE_ORDER_TEMPLATE_ID=""

# Email qua webhook tùy chọn
EMAIL_WEBHOOK_URL=""
EMAIL_WEBHOOK_TOKEN=""

# Bảo vệ endpoint chạy hàng đợi nếu gọi bằng cron HTTP
CRON_SECRET="replace-with-a-random-cron-secret"

# =========================
# TÀI KHOẢN KHỞI TẠO GỐC
# =========================
SEED_SUPER_ADMIN_PHONE=""
SEED_SUPER_ADMIN_PASSWORD=""
SEED_SUPER_ADMIN_NAME="SUPER ADMIN KOSOVOTA"
SEED_ADMIN_PHONE=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin vận hành KOSOVOTA"

# =========================
# OBJECT STORAGE: có thể local khi test, R2 khi production
# =========================
STORAGE_PROVIDER="local"
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_REGION="auto"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Chỉ bật khi chủ động dùng file local ở production. Khuyến nghị giữ false và dùng R2.
ALLOW_LOCAL_UPLOADS="false"
# Chỉ dùng local test. Endpoint seed demo luôn bị khóa khi NODE_ENV=production.
ALLOW_DEMO_SEED="false"

# =========================
# KIỂM THỬ TÍCH HỢP V19
# =========================
# JSON phải khớp đúng tên biến của template Zalo đã được duyệt.
ZALO_ZBS_TEST_TEMPLATE_DATA='{"otp":"123456","code":"123456","expire_time":"5 phút","message":"KOSOVOTA kiểm tra kết nối"}'
# Chỉ dùng cho lệnh npm run test:sms / test:zalo
TEST_PHONE=""
# Chỉ dùng cho lệnh npm run test:map
TEST_ADDRESS="Hồ Hoàn Kiếm, Hà Nội"
